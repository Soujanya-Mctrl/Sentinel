{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./frontend/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "frontend/next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "frontend/.next/types/**/*.ts",
    "frontend/.next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "**/node_modules/**", "contracts/artifacts", "contracts/cache", "cache", "**/cache/**"]
}
